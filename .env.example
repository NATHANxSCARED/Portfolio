# Email Configuration for Docker Compose
# Visit https://mailtrap.io for free tier (500 emails/month)
# OR use Gmail with App Password: https://myaccount.google.com/apppasswords

# Using Mailtrap (Recommended for free tier)
SMTP_HOST=live.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_email@mailtrap.io
SMTP_PASS=your_mailtrap_password

# OR Using Gmail
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Email Configuration
EMAIL_FROM=noreply@portfolio.com
EMAIL_TO=your_email@example.com

# Node Environment
NODE_ENV=production

# CORS
CORS_ORIGIN=http://localhost:3000
